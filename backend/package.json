{
  "name": "dummy-backend",
  "version": "0.1.0",
  "description": "더미 프로젝트 백엔드 (Nest.js 11 + Knex + PostgreSQL)",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start:prod": "node dist/main",
    "dev": "cross-env NODE_ENV=local nest start --watch",
    "db:migrate:local": "cross-env NODE_ENV=local npx knex migrate:latest --env local",
    "db:seed:local": "cross-env NODE_ENV=local npx knex seed:run --env local",
    "db:reset:local": "cross-env NODE_ENV=local npx knex migrate:rollback --env local && npm run db:migrate:local",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/passport": "^11.0.5",
    "knex": "^3.1.0",
    "nest-knexjs": "^0.0.34",
    "pg": "^8.19.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "jsonwebtoken": "^9.0.3",
    "bcrypt": "^6.0.0",
    "class-validator": "^0.15.1",
    "class-transformer": "^0.5.1",
    "dotenv": "^17.3.1",
    "axios": "^1.13.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^30.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "supertest": "^7.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2"
  }
}
